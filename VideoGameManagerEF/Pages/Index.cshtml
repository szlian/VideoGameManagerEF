@page
@model VideoGameManagerEF.Pages.IndexModel
@{
    ViewData["Title"] = "Home";
}

<div class="text-center mb-4">
    <h1 class="display-4">Video Game Manager</h1>
    <p class="lead">Game collection with Entity Framework Core and SQL Server.</p>
</div>

@if (Model.Games.Count == 0)
{
    <div class="alert alert-warning">
        <strong>No data found.</strong> The database is empty. Refresh this page to seed test data.
    </div>
}
else
{
    <div class="alert alert-info">
        <strong>@Model.Games.Count</strong> games and <strong>@Model.Developers.Count</strong> developers loaded from the database.
    </div>

    <div class="row">
        <div class="col-md-8">
            <div class="card mb-4">
                <div class="card-header bg-primary text-white">Games</div>
                <div class="card-body">
                    <table class="table table-striped table-hover">
                        <thead>
                            <tr>
                                <th>Title</th>
                                <th>Genre</th>
                                <th>Year</th>
                                <th>Score</th>
                                <th>Developer</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var game in Model.Games)
                            {
                                <tr>
                                    <td>@game.Title</td>
                                    <td>@game.Genre</td>
                                    <td>@game.Year</td>
                                    <td>@game.Score</td>
                                    <td>@(game.Developer?.Name ?? "Unknown")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card mb-4">
                <div class="card-header bg-secondary text-white">Developers</div>
                <div class="card-body">
                    <ul class="list-group">
                        @foreach (var dev in Model.Developers)
                        {
                            <li class="list-group-item d-flex justify-content-between">
                                @dev.Name
                                <span class="badge bg-secondary">@dev.Games.Count games</span>
                            </li>
                        }
                    </ul>
                </div>
            </div>

            <div class="card">
                <div class="card-header bg-dark text-white">Quick Links</div>
                <div class="card-body">
                    <a class="btn btn-success w-100 mb-2" asp-page="/Games/Index">Manage Games</a>
                    <a class="btn btn-info w-100 mb-2" asp-page="/Developers/Index">Manage Developers</a>
                    <a class="btn btn-warning w-100" asp-page="/Stats/Index">View Statistics</a>
                </div>
            </div>
        </div>
    </div>
}