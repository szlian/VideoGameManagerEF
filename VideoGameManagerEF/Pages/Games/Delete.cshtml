@page "{id:int}"
@model VideoGameManagerEF.Pages.Games.DeleteModel
@{
    ViewData["Title"] = "Delete Game";
}

<h1>Delete Game</h1>

<div class="alert alert-danger">
    <h3>Are you sure you want to delete this?</h3>
</div>

<div class="card">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-2">Title</dt>
            <dd class="col-sm-10">@Model.Game.Title</dd>

            <dt class="col-sm-2">Genre</dt>
            <dd class="col-sm-10">@Model.Game.Genre</dd>

            <dt class="col-sm-2">Year</dt>
            <dd class="col-sm-10">@Model.Game.Year</dd>

            <dt class="col-sm-2">Score</dt>
            <dd class="col-sm-10">@Model.Game.Score</dd>

            <dt class="col-sm-2">Developer</dt>
            <dd class="col-sm-10">@(Model.Game.Developer?.Name ?? "Unknown")</dd>
        </dl>
    </div>
</div>

<form method="post" class="mt-3">
    <input type="hidden" asp-for="Game.Id" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a class="btn btn-secondary" asp-page="Index">Cancel</a>
</form>