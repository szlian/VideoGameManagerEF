@page
@model VideoGameManagerEF.Pages.Games.IndexModel
@{
    ViewData["Title"] = "Games";
}

<h1>Game Collection</h1>

<p>
    <a class="btn btn-success" asp-page="Create">Add New Game</a>
</p>

@if (Model.Games.Count == 0)
{
    <div class="alert alert-warning">
        No games found. Visit the <a asp-page="/Index">home page</a> to seed data.
    </div>
}
else
{
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>Title</th>
                <th>Genre</th>
                <th>Year</th>
                <th>Score</th>
                <th>Platform</th>
                <th>Developer</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var game in Model.Games)
            {
                <tr>
                    <td>@game.Title</td>
                    <td>@game.Genre</td>
                    <td>@game.Year</td>
                    <td>@game.Score</td>
                    <td>@(game.Platform ?? "-")</td>
                    <td>@(game.Developer?.Name ?? "Unknown")</td>
                    <td>
                        <a class="btn btn-sm btn-primary" asp-page="Edit" asp-route-id="@game.Id">Edit</a>
                        <a class="btn btn-sm btn-info" asp-page="Details" asp-route-id="@game.Id">Details</a>
                        <a class="btn btn-sm btn-danger" asp-page="Delete" asp-route-id="@game.Id">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}