@page "{id:int}"
@model VideoGameManagerEF.Pages.Developers.DetailsModel
@{
    ViewData["Title"] = "Developer Details";
}

<h1>@Model.Developer.Name</h1>

<div class="row">
    <div class="col-md-4">
        <div class="card mb-3">
            <div class="card-header bg-dark text-white">Info</div>
            <div class="card-body">
                <p><strong>Country:</strong> @Model.Developer.Country</p>
                <p><strong>Founded:</strong> @Model.Developer.FoundedYear</p>
                <p><strong>Total Games:</strong> @Model.Developer.Games.Count</p>
            </div>
        </div>
        <a class="btn btn-secondary" asp-page="Index">Back to List</a>
    </div>

    <div class="col-md-8">
        <div class="card">
            <div class="card-header bg-primary text-white">Games by this Developer</div>
            <div class="card-body">
                @if (!Model.Developer.Games.Any())
                {
                    <p class="text-muted">No games registered for this developer.</p>
                }
                else
                {
                    <table class="table table-sm table-striped">
                        <thead>
                            <tr>
                                <th>Title</th>
                                <th>Genre</th>
                                <th>Year</th>
                                <th>Score</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var game in Model.Developer.Games)
                            {
                                <tr>
                                    <td>@game.Title</td>
                                    <td>@game.Genre</td>
                                    <td>@game.Year</td>
                                    <td>@game.Score</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    </div>
</div>